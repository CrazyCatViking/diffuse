+export function buildReport(input: Input) {
+  const generatedAt = new Date().toISOString();
+  const rows = [];
+  let done = 0;
+
+  for (const item of input.items) {
+    const row = {
+      id: item.id,
+      label: item.title.trim(),
+      owner: item.owner ?? 'unassigned',
+      status: item.state,
+    };
+    if (row.status === 'done') done += 1;
+    rows.push(row);
+  }
+
+  return {
+    generatedAt,
+    rows,
+    totals: { count: rows.length, done },
+  };
+}
